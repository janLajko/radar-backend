# Copy this file to .env for local development.
DATABASE_DSN_RADAR=postgresql://user:password@host:5432/dbname
SOURCE_CONFIG_PATH=config/sources.yaml

LLM_PROVIDER=openai
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o
POLICY_UPDATE_LLM_MODEL=gpt-4o
POLICY_IMPACT_LLM_MODEL=gpt-4o

ANTHROPIC_API_KEY=sk-ant-...

WORKER_POLL_INTERVAL_SECONDS=300
DB_POOL_MIN_SIZE=10
DB_POOL_MAX_SIZE=50
DB_POOL_TIMEOUT_SECONDS=60
LOG_LEVEL=INFO
